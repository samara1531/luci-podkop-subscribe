#!/bin/sh
# Auto-update Podkop subscribe configs:
# - refresh subscription
# - ping hosts
# - merge multiple sources (subscriptions + manual links)
# - set best config for URL mode and lists for URLTest/Selector

set -e

STATE_DIR="/tmp/podkop-subscribe-autoupdate"
TMP_ROOT="/tmp/podkop-subscribe-autoupdate-work"
mkdir -p "$STATE_DIR" "$TMP_ROOT"

FORCE_MODE=0
FORCE_SECTION=""
NO_APPLY=0
while [ $# -gt 0 ]; do
    case "$1" in
        --force)
            FORCE_MODE=1
            FORCE_SECTION="$2"
            shift 2
            ;;
        --no-apply)
            NO_APPLY=1
            shift
            ;;
        *)
            shift
            ;;
    esac
done

to_lower() {
    printf '%s' "$1" | tr '[:upper:]' '[:lower:]'
}

trim() {
    # shellcheck disable=SC2001
    printf '%s' "$1" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//'
}

uci_list_values() {
    section="$1"
    option="$2"
    uci -q show podkop 2>/dev/null | sed -n "s/^podkop\\.${section}\\.${option}='\\(.*\\)'$/\\1/p"
}

url_decode() {
    printf '%b' "$(printf '%s' "$1" | sed 's/+/ /g;s/%\([0-9A-Fa-f][0-9A-Fa-f]\)/\\x\1/g')" 2>/dev/null || printf '%s' "$1"
}

interval_to_seconds() {
    case "$1" in
        *m) printf '%s' "$(( ${1%m} * 60 ))" ;;
        *h) printf '%s' "$(( ${1%h} * 3600 ))" ;;
        *d) printf '%s' "$(( ${1%d} * 86400 ))" ;;
        *)  printf '3600' ;;
    esac
}

should_run_now() {
    section="$1"
    interval="$2"
    now="$(date +%s)"
    last_file="$STATE_DIR/$section.last"
    sec="$(interval_to_seconds "$interval")"
    [ -z "$sec" ] && sec=3600
    [ "$sec" -le 0 ] && sec=3600
    [ ! -f "$last_file" ] && return 0
    last="$(cat "$last_file" 2>/dev/null || echo 0)"
    [ -z "$last" ] && last=0
    [ $((now - last)) -ge "$sec" ]
}

mark_run_now() {
    section="$1"
    date +%s > "$STATE_DIR/$section.last"
}

write_status() {
    section="$1"
    shift
    status_file="$STATE_DIR/$section.status"
    : > "$status_file"
    for kv in "$@"; do
        printf '%s\n' "$kv" >> "$status_file"
    done
}

sanitize_status_value() {
    printf '%s' "$1" | tr '\r\n' ' ' | sed 's/[[:space:]]\+/ /g;s/^ //;s/ $//'
}

extract_title() {
    line="$1"
    title="$(printf '%s' "$line" | sed -n 's/.*#\(.*\)$/\1/p')"
    [ -z "$title" ] && title="$2"
    url_decode "$title"
}

extract_host() {
    url="$1"
    case "$url" in
        vless://*|trojan://*|hy2://*|hysteria2://*|socks://*|socks4://*|socks5://*)
            core="${url#*://}"
            case "$core" in
                *@*) core="${core#*@}" ;;
            esac
            core="$(printf '%s' "$core" | sed 's/[\/?#].*$//')"
            if printf '%s' "$core" | grep -qE '^\[[^]]+\]:'; then
                printf '%s' "$core" | sed 's/^\[\([^]]*\)\].*$/\1/'
            else
                printf '%s' "$core" | sed 's/:.*$//'
            fi
            ;;
        ss://*)
            core="${url#ss://}"
            case "$core" in
                *@*)
                    core="${core#*@}"
                    core="$(printf '%s' "$core" | sed 's/[\/?#].*$//')"
                    printf '%s' "$core" | sed 's/:.*$//'
                    ;;
                *)
                    enc="$(printf '%s' "$core" | sed 's/[\/?#].*$//')"
                    dec="$(printf '%s' "$enc" | base64 -d 2>/dev/null || true)"
                    if printf '%s' "$dec" | grep -q '@'; then
                        hostpart="${dec#*@}"
                        printf '%s' "$hostpart" | sed 's/:.*$//'
                    else
                        printf ''
                    fi
                    ;;
            esac
            ;;
        *)
            printf ''
            ;;
    esac
}

ping_latency() {
    host="$1"
    [ -z "$host" ] && { printf '999999'; return; }
    line="$(ping -c 1 -W 1 "$host" 2>/dev/null | sed -n 's/.*time=\([0-9.]*\).*/\1/p' | head -n1)"
    [ -z "$line" ] && { printf '999999'; return; }
    printf '%s' "$line" | awk -F. '{print $1}'
}

fetch_subscription_lines() {
    sub_url="$1"
    out_file="$2"
    raw_file="$TMP_ROOT/raw.$$"
    dec_file="$TMP_ROOT/dec.$$"

    if ! wget -q -O "$raw_file" --timeout=30 --user-agent="v2rayNG" "$sub_url" 2>/dev/null; then
        rm -f "$raw_file" "$dec_file"
        return 1
    fi
    if [ ! -s "$raw_file" ]; then
        rm -f "$raw_file" "$dec_file"
        return 1
    fi
    if ! base64 -d "$raw_file" > "$dec_file" 2>/dev/null; then
        rm -f "$raw_file" "$dec_file"
        return 1
    fi

    idx=$(( $(wc -l < "$out_file" 2>/dev/null || echo 0) + 1 ))
    while IFS= read -r line || [ -n "$line" ]; do
        clean="$(printf '%s' "$line" | tr -d '\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        [ -z "$clean" ] && continue
        case "$clean" in
            vless://*|ss://*|trojan://*|hy2://*|hysteria2://*|socks://*|socks4://*|socks5://*)
                title="$(extract_title "$clean" "Config $idx")"
                printf '%s\t%s\n' "$clean" "$title" >> "$out_file"
                idx=$((idx + 1))
                ;;
        esac
    done < "$dec_file"

    rm -f "$raw_file" "$dec_file"
    [ -s "$out_file" ]
}

append_manual_lines() {
    section="$1"
    out_file="$2"
    idx=$(( $(wc -l < "$out_file" 2>/dev/null || echo 0) + 1 ))
    manual_lines="$(uci_list_values "$section" "subscribe_manual_links" || true)"
    [ -z "$manual_lines" ] && return 1

    appended=0
    while IFS= read -r line || [ -n "$line" ]; do
        clean="$(printf '%s' "$line" | tr -d '\r' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        [ -z "$clean" ] && continue
        case "$clean" in
            vless://*|ss://*|trojan://*|hy2://*|hysteria2://*|socks://*|socks4://*|socks5://*)
                title="$(extract_title "$clean" "Manual $idx")"
                printf '%s\t%s\n' "$clean" "$title" >> "$out_file"
                idx=$((idx + 1))
                appended=1
                ;;
        esac
    done <<EOF
$manual_lines
EOF

    [ "$appended" -eq 1 ]
}

apply_mode_url() {
    section="$1"
    best_url="$2"
    [ -z "$best_url" ] && return
    uci -q set "podkop.$section.proxy_string=$best_url"
}

apply_mode_list() {
    section="$1"
    list_option="$2"
    ranked_file="$3"
    max_items="$4"
    count=0

    uci -q delete "podkop.$section.$list_option" || true
    while IFS="$(printf '\t')" read -r _lat url _title; do
        [ -z "$url" ] && continue
        uci -q add_list "podkop.$section.$list_option=$url"
        count=$((count + 1))
        [ "$count" -ge "$max_items" ] && break
    done < "$ranked_file"
}

is_blocked_url() {
    url="$1"
    blocked_urls="$2"
    IFS=','
    for item in $blocked_urls; do
        b="$(trim "$item")"
        [ -z "$b" ] && continue
        [ "$url" = "$b" ] && unset IFS && return 0
    done
    unset IFS
    return 1
}

process_section() {
    section="$1"
    mode="unknown"
    total_count=0
    eligible_count=0
    excluded_count=0
    best_title=""
    changed=0
    applied_count=0
    note=""
    status="ok"

    if [ "$FORCE_MODE" -eq 1 ] && [ -n "$FORCE_SECTION" ] && [ "$section" != "$FORCE_SECTION" ]; then
        return 0
    fi

    connection_type="$(uci -q get "podkop.$section.connection_type" || echo '')"
    if [ "$connection_type" != "proxy" ]; then
        [ "$FORCE_MODE" -eq 1 ] && write_status "$section" "status=skipped" "reason=connection_type_not_proxy"
        return 0
    fi

    if [ "$FORCE_MODE" -ne 1 ]; then
        auto="$(uci -q get "podkop.$section.subscribe_auto_update" || echo '0')"
        [ "$auto" = "1" ] || return 0

        interval="$(uci -q get "podkop.$section.subscribe_update_interval" || echo '1h')"
        should_run_now "$section" "$interval" || return 0
    fi

    mode="$(uci -q get "podkop.$section.proxy_config_type" || echo 'url')"
    case "$mode" in
        url|urltest|selector|outbound) ;;
        *)
            mark_run_now "$section"
            [ "$FORCE_MODE" -eq 1 ] && write_status "$section" "status=skipped" "reason=unsupported_mode" "mode=$mode"
            return 0
            ;;
    esac

    if [ "$mode" = "outbound" ]; then
        primary_url="$(uci -q get "podkop.$section.subscribe_url_outbound" || echo '')"
        extra_option="subscribe_urls_extra_outbound"
    else
        primary_url="$(uci -q get "podkop.$section.subscribe_url" || echo '')"
        extra_option="subscribe_urls_extra"
    fi

    blocked_urls="$(uci -q get "podkop.$section.subscribe_blocked_urls" || echo '')"
    max_items="$(uci -q get "podkop.$section.subscribe_max_configs" || echo '20')"
    case "$max_items" in
        ''|*[!0-9]*) max_items=20 ;;
    esac
    [ "$max_items" -lt 1 ] && max_items=20
    [ "$max_items" -gt 200 ] && max_items=200

    lines_file="$TMP_ROOT/lines.$section.$$"
    ranked_file="$TMP_ROOT/ranked.$section.$$"
    source_urls_file="$TMP_ROOT/source_urls.$section.$$"
    dedup_file="$TMP_ROOT/dedup.$section.$$"
    : > "$lines_file"
    : > "$ranked_file"
    : > "$source_urls_file"

    [ -n "$primary_url" ] && printf '%s\n' "$primary_url" >> "$source_urls_file"
    uci_list_values "$section" "$extra_option" >> "$source_urls_file" 2>/dev/null || true
    manual_sources="$(uci_list_values "$section" "subscribe_manual_links" || true)"

    if [ ! -s "$source_urls_file" ] && [ -z "$manual_sources" ]; then
        rm -f "$lines_file" "$ranked_file" "$source_urls_file" "$dedup_file"
        mark_run_now "$section"
        [ "$FORCE_MODE" -eq 1 ] && write_status "$section" "status=skipped" "reason=empty_sources" "mode=$mode"
        return 0
    fi

    fetched_any=0
    if [ -s "$source_urls_file" ]; then
        while IFS= read -r sub_url || [ -n "$sub_url" ]; do
            clean_sub_url="$(trim "$sub_url")"
            [ -z "$clean_sub_url" ] && continue
            if fetch_subscription_lines "$clean_sub_url" "$lines_file"; then
                fetched_any=1
            fi
        done < "$source_urls_file"
    fi

    manual_any=0
    if append_manual_lines "$section" "$lines_file"; then
        manual_any=1
    fi

    if [ "$fetched_any" -ne 1 ] && [ "$manual_any" -ne 1 ]; then
        rm -f "$lines_file" "$ranked_file" "$source_urls_file" "$dedup_file"
        mark_run_now "$section"
        [ "$FORCE_MODE" -eq 1 ] && write_status "$section" "status=error" "reason=fetch_or_decode_failed" "mode=$mode"
        return 0
    fi

    if [ ! -s "$lines_file" ]; then
        rm -f "$lines_file" "$ranked_file" "$source_urls_file" "$dedup_file"
        mark_run_now "$section"
        [ "$FORCE_MODE" -eq 1 ] && write_status "$section" "status=error" "reason=no_valid_configs" "mode=$mode"
        return 0
    fi

    awk -F "$(printf '\t')" '!seen[$1]++' "$lines_file" > "$dedup_file"
    mv "$dedup_file" "$lines_file"

    total_count="$(wc -l < "$lines_file" 2>/dev/null || echo 0)"

    while IFS="$(printf '\t')" read -r url title; do
        [ -z "$url" ] && continue
        if is_blocked_url "$url" "$blocked_urls"; then
            excluded_count=$((excluded_count + 1))
            continue
        fi
        eligible_count=$((eligible_count + 1))
        host="$(extract_host "$url")"
        lat="$(ping_latency "$host")"
        printf '%s\t%s\t%s\n' "$lat" "$url" "$title" >> "$ranked_file"
    done < "$lines_file"

    if [ ! -s "$ranked_file" ]; then
        rm -f "$lines_file" "$ranked_file" "$source_urls_file" "$dedup_file"
        mark_run_now "$section"
        [ "$FORCE_MODE" -eq 1 ] && write_status "$section" \
            "status=ok" "mode=$mode" "total=$total_count" "eligible=0" "excluded=$excluded_count" \
            "applied=0" "changed=0" "note=no_eligible_configs_after_filters"
        return 0
    fi

    sort -t "$(printf '\t')" -k1,1n "$ranked_file" -o "$ranked_file"
    best_url="$(head -n1 "$ranked_file" | cut -f2)"
    best_title="$(head -n1 "$ranked_file" | cut -f3)"

    if [ "$NO_APPLY" -eq 1 ]; then
        note="ping_only_no_apply"
        changed=0
        applied_count=0
    else
        case "$mode" in
            url)
                current_url="$(uci -q get "podkop.$section.proxy_string" || echo '')"
                apply_mode_url "$section" "$best_url"
                [ "$best_url" != "$current_url" ] && changed=1 || changed=0
                applied_count=1
                ;;
            urltest)
                apply_mode_list "$section" "urltest_proxy_links" "$ranked_file" "$max_items"
                applied_count="$max_items"
                [ "$eligible_count" -lt "$max_items" ] && applied_count="$eligible_count"
                changed=1
                ;;
            selector)
                apply_mode_list "$section" "selector_proxy_links" "$ranked_file" "$max_items"
                applied_count="$max_items"
                [ "$eligible_count" -lt "$max_items" ] && applied_count="$eligible_count"
                changed=1
                ;;
            outbound)
                # Outbound uses manual JSON apply in LuCI; we only refresh timing state.
                note="outbound_mode_manual_json_apply"
                ;;
        esac
    fi

    if [ "$FORCE_MODE" -eq 1 ]; then
        write_status "$section" \
        "status=$status" "mode=$mode" "total=$total_count" "eligible=$eligible_count" "excluded=$excluded_count" \
        "best_title=$(sanitize_status_value "$best_title")" "best_url=$best_url" \
        "applied=$applied_count" "changed=$changed" "note=$note"
        status_file="$STATE_DIR/$section.status"
        rank_idx=0
        while IFS="$(printf '\t')" read -r lat url title; do
            rank_idx=$((rank_idx + 1))
            [ "$rank_idx" -gt 500 ] && break
            printf 'top%s_title=%s\n' "$rank_idx" "$(sanitize_status_value "$title")" >> "$status_file"
            printf 'top%s_ping=%s\n' "$rank_idx" "$lat" >> "$status_file"
            printf 'top%s_url=%s\n' "$rank_idx" "$url" >> "$status_file"
            printf 'top%s_host=%s\n' "$rank_idx" "$(extract_host "$url")" >> "$status_file"
        done < "$ranked_file"
    fi

    rm -f "$lines_file" "$ranked_file" "$source_urls_file" "$dedup_file"
    mark_run_now "$section"
}

sections="$(uci -q show podkop 2>/dev/null | sed -n 's/^podkop\.\([^.=]*\)=section$/\1/p')"
[ -n "$sections" ] || exit 0

for sec in $sections; do
    process_section "$sec" || true
done

uci -q commit podkop || true

exit 0
