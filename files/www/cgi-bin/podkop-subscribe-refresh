#!/bin/sh
# Run subscribe auto-update immediately for a specific section

. /usr/share/libubox/jshn.sh

echo "Content-Type: application/json"
echo ""

read -r POST_DATA
POST_DATA="$(printf '%s' "$POST_DATA" | tr -d '\r')"

section_id=""
blocked_urls=""
blocked_urls_provided="0"

if printf '%s' "$POST_DATA" | grep -q '^[[:space:]]*{'; then
    section_id="$(printf '%s' "$POST_DATA" | jsonfilter -e '@.section_id' 2>/dev/null || true)"
    blocked_urls="$(printf '%s' "$POST_DATA" | jsonfilter -e '@.blocked_urls' 2>/dev/null || true)"
    blocked_urls_provided="1"
else
    section_id="$POST_DATA"
fi

section_id="$(printf '%s' "$section_id" | tr -d '\r\n')"
blocked_urls="$(printf '%s' "$blocked_urls" | tr -d '\r\n')"

if [ -z "$section_id" ]; then
    json_init
    json_add_string "error" "section_id is required"
    json_dump
    exit 1
fi

if [ ! -x /usr/bin/podkop-subscribe-autoupdate ]; then
    json_init
    json_add_string "error" "auto-update script is not installed"
    json_dump
    exit 1
fi

run_log="$(PODKOP_BLOCKED_URLS="$blocked_urls" PODKOP_BLOCKED_URLS_PROVIDED="$blocked_urls_provided" /usr/bin/podkop-subscribe-autoupdate --force "$section_id" 2>&1)"
run_rc=$?
status_file="/tmp/podkop-subscribe-autoupdate/${section_id}.status"

if [ $run_rc -eq 0 ]; then
    json_init
    json_add_boolean "success" 1
    json_add_string "message" "Auto-update completed"

    if [ -f "$status_file" ]; then
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            key="${line%%=*}"
            val="${line#*=}"
            [ -z "$key" ] && continue
            json_add_string "$key" "$val"
        done < "$status_file"
    fi

    json_dump
    exit 0
fi

json_init
json_add_string "error" "Auto-update failed"
json_add_string "details" "$run_log"
json_dump
exit 1
